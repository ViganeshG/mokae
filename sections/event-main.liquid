{%- liquid
  assign host = product.metafields.gax.event_host.value | default: product.metafields.custom.event_host.value | default: product.metafields.gax.event_host | default: product.metafields.custom.event_host
  assign event_summary = product.metafields.gax.event_summary.value | default: product.metafields.custom.event_summary.value | default: product.metafields.gax.event_summary | default: product.metafields.custom.event_summary
  assign event_images = product.metafields.gax.event_images.value | default: product.metafields.custom.event_images.value
  assign join_event_label = product.metafields.gax.join_event_label | default: 'book now'
  assign pdt_price = product.price | money_with_currency
  assign event_details_raw = product.metafields.gax.event_details.value | default: product.metafields.custom.event_details.value | default: product.metafields.gax.event_details | default: product.metafields.custom.event_details
  assign event_details = event_details_raw | replace_first: '$price', pdt_price | newline_to_br
  assign is_past_event = false
  assign event_date = product.metafields.gax.event_date.value | default: product.metafields.custom.event_date.value | default: product.metafields.gax.event_date | default: product.metafields.custom.event_date
  assign event_timings = product.metafields.custom.event_timings.value | default: product.metafields.custom.event_timings
  assign tbc_event = false
  assign event_time = event_details | split: '<br />' | first
  assign event_checkout_mode = product.metafields.custom.event_checkout_mode.value | default: '' | strip | downcase
  assign is_event_template = false
  if template.suffix == 'event'
    assign is_event_template = true
  endif
  assign event_row_show_timings_price = false
  if event_timings != blank
    assign event_row_show_timings_price = true
  endif
  assign is_waitlist_event = false
  if product.tags contains 'waitlist' or product.tags contains 'event-waitlist'
    assign is_waitlist_event = true
  endif
  if event_date == blank and event_timings == blank
    assign tbc_event = true
  endif

  if event_date != blank
    assign input_date = event_date | date: '%s'
    assign current_date = 'now' | date: '%s'

    if input_date < current_date
      assign is_past_event = true
    endif
  endif

  assign event_hero = product.featured_image
  if event_hero == blank and event_images != blank
    assign event_hero = event_images | first
  endif

  assign event_gallery = product.images
  if event_gallery.size == 0 and event_images != blank
    assign event_gallery = event_images
  endif

  assign payment_link = section.settings.cta_button_link | strip
  assign payment_label = section.settings.cta_button_text | default: join_event_label
  assign event_variant = product.selected_or_first_available_variant
  if event_variant == blank and product.variants.size > 0
    assign event_variant = product.variants.first
  endif
  assign use_shopify_checkout = false
  if event_checkout_mode == 'shopify_checkout' or event_checkout_mode == 'online'
    assign use_shopify_checkout = true
  endif
  assign use_payment_link = false
  if payment_link != blank
    if event_checkout_mode == 'razorpay' or event_checkout_mode == 'payment_link' or event_checkout_mode == 'offline'
      assign use_payment_link = true
    endif
  endif
  if use_shopify_checkout
    assign use_payment_link = false
  endif
  if use_payment_link and payment_link == blank
    assign use_payment_link = false
  endif
  assign show_waitlist_cta = is_waitlist_event
  assign show_book_cta = false
  unless is_waitlist_event
    assign show_book_cta = true
  endunless
  assign sticky_cta_label = join_event_label
  if show_waitlist_cta
    assign sticky_cta_label = 'Join the Waitlist'
  elsif use_payment_link
    assign sticky_cta_label = payment_label
  endif

  assign any_variant_timings = false
  for v in product.variants
    if v.metafields.custom.event_timings != blank
      assign any_variant_timings = true
      break
    endif
  endfor
  assign show_timings_tile = false
  if event_timings != blank or any_variant_timings
    assign show_timings_tile = true
  endif
  assign current_variant_date = event_variant.metafields.custom.event_date.value | default: event_variant.metafields.custom.event_date | default: event_date
  assign current_variant_time = event_variant.metafields.custom.event_timings.value | default: event_variant.metafields.custom.event_timings | default: event_timings
  assign current_variant_wte = event_variant.metafields.custom.what_to_expect
  if current_variant_wte == blank
    assign current_variant_wte = product.metafields.custom.what_to_expect
  endif

  assign has_other_accordion = false
  if product.metafields.custom.beauty_bar_experience != blank or product.metafields.custom.who_is_this_for != blank or product.metafields.custom.event_flow != blank
    assign has_other_accordion = true
  endif

-%}
{% if is_past_event != true %}
  <div class="pdt-details-wr">
    <div class="pd-inner ga-section-container pd-inner--{% if event_hero != blank %}has-image{% else %}no-image{% endif %}">
      {%- if event_hero != blank -%}
        <div class="pd-media-column">
          <div class="pd-image-wr">
            {%- if event_gallery.size > 1 -%}
              <div class="pd-carousel" data-pd-carousel>
                <div class="pd-carousel__viewport" data-pd-carousel-viewport>
                  {%- for image in event_gallery -%}
                    <div class="pd-carousel__slide">
                      {%- if forloop.first -%}
                        {{ image | image_url: width: 1600 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '400, 600, 800, 1000, 1200, 1600', sizes: '(min-width: 990px) 44vw, 100vw', class: 'pd-carousel__img' }}
                      {%- else -%}
                        {{ image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '400, 600, 800, 1000, 1200, 1600', sizes: '(min-width: 990px) 44vw, 100vw', class: 'pd-carousel__img' }}
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
                <button type="button" class="pd-carousel__arrow pd-carousel__arrow--prev" data-pd-carousel-prev aria-label="Previous image">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
                <button type="button" class="pd-carousel__arrow pd-carousel__arrow--next" data-pd-carousel-next aria-label="Next image">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
                <div class="pd-carousel__dots" data-pd-carousel-dots>
                  {%- for image in event_gallery -%}
                    <button type="button" class="pd-carousel__dot{% if forloop.first %} is-active{% endif %}" data-pd-carousel-dot aria-label="Go to image {{ forloop.index }}"></button>
                  {%- endfor -%}
                </div>
              </div>
            {%- else -%}
              {{
                event_hero
                | image_url: width: 2000
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  widths: '750, 1100, 1500, 2000',
                  sizes: '(min-width: 990px) 44vw, 100vw',
                  class: 'pd-image'
              }}
            {%- endif -%}
          </div>
          <div class="pd-event-actions" data-event-actions data-event-booking-anchor>
      {%- else -%}
        <div class="pd-content-head">
          <h1 class="pd-title">{{ product.title }}</h1>
          {% if host != blank %}
            <div class="pd-event-host">{{ host }}</div>
          {% endif %}
          {% if product.metafields.custom.event_tagline != blank %}
            <h3 class="pd-event-tagline">{{ product.metafields.custom.event_tagline }}</h3>
          {% endif %}
        </div>
        <div class="pd-event-actions" data-event-actions data-event-booking-anchor>
      {%- endif -%}
          {% if current_variant_date != blank
            or show_timings_tile
            or product.metafields.custom.event_location != blank
          %}
            <div class="pd-event-details-grid">
              <h3 class="pd-event-details-heading">EVENT DETAILS</h3>
              {% if current_variant_date != blank %}
                <div class="pd-event-tile pd-event-tile--date">
                  <span class="pd-event-tile__label">Date</span>
                  <span class="pd-event-tile__value" data-event-date-value>{{ current_variant_date | date: '%d %B %Y' }}</span>
                </div>
              {% endif %}
              {% if product.metafields.custom.event_location != blank
                or show_timings_tile
              %}
                <div
                  class="pd-event-details-location-row{% if product.metafields.custom.event_location == blank %} pd-event-details-location-row--no-location{% elsif event_row_show_timings_price == false %} pd-event-details-location-row--location-only{% endif %}"
                >
                  {% if product.metafields.custom.event_location != blank %}
                    <div class="pd-event-tile pd-event-tile--location">
                      <span class="pd-event-tile__label">Location</span>
                      <span class="pd-event-tile__value">{{ product.metafields.custom.event_location }}</span>
                    </div>
                  {% endif %}
                  {% if show_timings_tile %}
                    <div class="pd-event-tile pd-event-tile--timings" data-event-timings-tile{% if current_variant_time == blank %} hidden{% endif %}>
                      <span class="pd-event-tile__label">Timings</span>
                      <span class="pd-event-tile__value" data-event-timings-value>{{ current_variant_time }}</span>
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if show_book_cta %}
            <div class="pd-event-primary-cta" data-event-primary-cta>
              {% if product.variants.size > 1 %}
                <div class="pd-event-variant-picker" data-event-variant-picker role="group" aria-label="Select your ticket">
                  {% for variant in product.variants %}
                    <button
                      type="button"
                      class="pd-event-variant-btn{% if variant.id == event_variant.id %} is-selected{% endif %}"
                      data-variant-select
                      data-variant-id="{{ variant.id }}"
                      data-available="{{ variant.available }}"
                      aria-pressed="{% if variant.id == event_variant.id %}true{% else %}false{% endif %}"
                    >
                      <span class="pd-event-variant-btn__title">{{ variant.title }}</span>
                      <span class="pd-event-variant-btn__price">{{ variant.price | money_without_trailing_zeros | strip_html }}{% unless variant.available %} · Sold out{% endunless %}</span>
                    </button>
                  {% endfor %}
                </div>
                <div class="pd-event-variant-select-wrap">
                  <label class="pd-event-variant-select-label" for="EventVariantSelect">Select your ticket</label>
                  <div class="pd-event-variant-select-control">
                    <select id="EventVariantSelect" class="pd-event-variant-select" data-event-variant-dropdown aria-label="Select your ticket">
                      {% for variant in product.variants %}
                        <option value="{{ variant.id }}"{% if variant.id == event_variant.id %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>{{ variant.title }} — {{ variant.price | money_without_trailing_zeros | strip_html }}{% unless variant.available %} (Sold out){% endunless %}</option>
                      {% endfor %}
                    </select>
                    <span class="pd-event-variant-select-arrow" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                  </div>
                </div>
                {% if current_variant_wte != blank %}
                  <div class="event-accordion event-accordion--mobile-wte" data-event-mobile-wte>
                    <div class="event-accordion-item event-accordion-item--static">
                      <div class="event-accordion-static-heading">WHAT TO EXPECT</div>
                      <div class="event-accordion-panel" data-what-to-expect-panel>
                        {{ current_variant_wte | metafield_tag }}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endif %}
              {% unless is_waitlist_event %}
                {% if product.selected_or_first_available_variant.price != blank %}
                  <p class="pd-event-price-per-seat">
                    <span class="pd-event-price-per-seat__amount">{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros | strip_html }}</span><span class="pd-event-price-per-seat__unit"> / per person</span>
                  </p>
                {% endif %}
              {% endunless %}
              <p class="pd-scarcity-line">Strictly Limited Capacity</p>
              {% if event_variant.available %}
                {% if use_payment_link %}
                  <a
                    href="{{ payment_link }}"
                    class="button button--primary pd-secure-seat-btn pd-cta-button"
                    target="_blank"
                    rel="noopener noreferrer"
                    data-event-book-now
                  >
                    {{- payment_label -}}
                  </a>
                {% elsif use_shopify_checkout %}
                  <form
                    method="post"
                    action="{{ routes.cart_add_url }}"
                    class="pd-event-booking-form"
                    data-event-booking-form
                    data-variant-id="{{ event_variant.id }}"
                  >
                    <input type="hidden" name="id" value="{{ event_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <input type="hidden" name="return_to" value="{{ routes.root_url }}checkout">
                    <div class="event-checkout-attendee-fields">
                      <input
                        type="text"
                        name="properties[Attendee name]"
                        class="event-checkout-input"
                        placeholder="Name"
                        autocomplete="name"
                        required
                      >
                      <input
                        type="email"
                        name="properties[Email]"
                        class="event-checkout-input"
                        placeholder="Email"
                        autocomplete="email"
                        required
                      >
                      <input
                        type="tel"
                        name="properties[Phone]"
                        class="event-checkout-input"
                        placeholder="Phone"
                        autocomplete="tel"
                        required
                      >
                    </div>
                    <p class="pd-qty-locked-hint">1 ticket per order</p>
                    <button type="submit" class="button button--primary pd-secure-seat-btn" data-event-book-now>
                      {{ join_event_label }}
                    </button>
                  </form>
                {% else %}
                  <form
                    method="post"
                    action="{{ routes.cart_add_url }}"
                    class="pd-event-booking-form"
                    data-event-booking-form
                    data-variant-id="{{ event_variant.id }}"
                  >
                    <input type="hidden" name="id" value="{{ event_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <input type="hidden" name="return_to" value="{{ routes.root_url }}checkout">
                    <button type="submit" class="button button--primary pd-secure-seat-btn" data-event-book-now>
                      {{ join_event_label }}
                    </button>
                  </form>
                {% endif %}
              {% else %}
                <button type="button" class="button button--primary pd-secure-seat-btn" disabled>
                  Sold Out
                </button>
              {% endif %}
            </div>
          {% endif %}

          <div class="pd-event-variant-payloads" data-event-variant-payloads hidden>
            {% for variant in product.variants %}
              {%- liquid
                assign p_date = variant.metafields.custom.event_date.value | default: variant.metafields.custom.event_date | default: event_date
                assign p_time = variant.metafields.custom.event_timings.value | default: variant.metafields.custom.event_timings | default: event_timings
              -%}
              <template
                data-variant-payload
                data-variant-id="{{ variant.id }}"
                data-price="{{ variant.price | money_without_trailing_zeros | strip_html }}"
                data-available="{{ variant.available }}"
                data-date="{% if p_date != blank %}{{ p_date | date: '%d %B %Y' }}{% endif %}"
                data-time="{{ p_time }}"
              >{% if variant.metafields.custom.what_to_expect != blank %}{{ variant.metafields.custom.what_to_expect | metafield_tag }}{% elsif product.metafields.custom.what_to_expect != blank %}{{ product.metafields.custom.what_to_expect | metafield_tag }}{% endif %}</template>
            {% endfor %}
          </div>

          {% if show_waitlist_cta %}
            <div
              class="event-waitlist-wr event-waitlist-wr--customer-lead"
              data-event-waitlist-anchor
            >
              <p class="pd-scarcity-line">Strictly Limited Capacity</p>
              {%- form 'customer', id: 'EventWaitlistOnlyForm', return_to: product.url -%}
                <input
                  type="hidden"
                  name="contact[tags]"
                  value="Event, event-waitlist, waitlist-{{ product.handle }}"
                >
                {%- if form.posted_successfully? -%}
                  <p class="waitlist-message success waitlist-message--success-standalone">
                    Thank you. You have been added to the waitlist.
                  </p>
                {%- else -%}
                  <div class="waitlist-form-fields">
                    <input
                      type="text"
                      name="contact[first_name]"
                      class="waitlist-input"
                      placeholder="Name"
                      autocomplete="given-name"
                      required
                      id="EventWaitlistOnly-first-name"
                      value="{% if form.first_name %}{{ form.first_name }}{% endif %}"
                    >
                    <input
                      type="email"
                      name="contact[email]"
                      class="waitlist-input"
                      placeholder="Email"
                      required
                      autocapitalize="off"
                      autocomplete="email"
                      id="EventWaitlistOnly-email"
                      value="{% if form.email %}{{ form.email }}{% endif %}"
                    >
                    <input
                      type="tel"
                      name="contact[phone]"
                      class="waitlist-input"
                      placeholder="Phone"
                      required
                      autocomplete="tel"
                      id="EventWaitlistOnly-phone"
                    >
                    <input
                      type="text"
                      name="contact[waitlist_city]"
                      class="waitlist-input"
                      placeholder="City"
                      required
                      id="EventWaitlistOnly-city"
                    >
                    <button type="submit" class="button button--primary waitlist-submit-btn waitlist-submit-btn--primary">
                      Join the Waitlist
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <p class="waitlist-message error">{{ form.errors | default_errors }}</p>
                  {%- endif -%}
                {%- endif -%}
              {%- endform -%}
            </div>
          {% endif %}
          {% if product.metafields.custom.event_phone != blank
            or product.metafields.custom.event_email != blank
            or product.metafields.custom.event_notice != blank
          %}
            <div class="pd-event-contact-below-cta">
              {% if product.metafields.custom.event_phone != blank %}
                <p class="pd-event-contact-line"><strong>Contact Us:</strong> {{ product.metafields.custom.event_phone }}</p>
              {% endif %}
              {% if product.metafields.custom.event_email != blank %}
                <p class="pd-event-contact-line"><strong>Email:</strong> {{ product.metafields.custom.event_email }}</p>
              {% endif %}
              {% if product.metafields.custom.event_notice != blank %}
                <p class="pd-event-contact-line"><strong>Contact Us:</strong> +91 8767790356</p>
                <p class="pd-event-contact-line pd-event-contact-line--notice">
                  <strong>{{ product.metafields.custom.event_notice }}</strong>
                </p>
              {% endif %}
            </div>
          {% endif %}
      </div>

      {%- if event_hero != blank -%}
        </div>
        <div class="pd-content-column">
          <div class="pd-content-head">
            <h1 class="pd-title">{{ product.title }}</h1>
            {% if host != blank %}
              <div class="pd-event-host">{{ host }}</div>
            {% endif %}
            {% if product.metafields.custom.event_tagline != blank %}
              <h3 class="pd-event-tagline">{{ product.metafields.custom.event_tagline }}</h3>
            {% endif %}
          </div>
          <div class="pd-content-body">
            {% if product.description != blank %}
              <div class="pd-desc rte">
                {{ product.description }}
              </div>
            {% endif %}

            {% if current_variant_wte != blank
              or product.metafields.custom.beauty_bar_experience != blank
              or product.metafields.custom.who_is_this_for != blank
              or product.metafields.custom.event_flow != blank
            %}
              <div class="event-accordion{% if product.variants.size > 1 and current_variant_wte != blank %}{% if has_other_accordion %} event-accordion--wte-mobile-hidden{% else %} event-accordion--has-mobile-copy{% endif %}{% endif %}">
                {% if current_variant_wte != blank %}
                  <div class="event-accordion-item event-accordion-item--static">
                    <div class="event-accordion-static-heading">WHAT TO EXPECT</div>
                    <div class="event-accordion-panel" data-what-to-expect-panel>
                      {{ current_variant_wte | metafield_tag }}
                    </div>
                  </div>
                {% endif %}
                {% if product.metafields.custom.beauty_bar_experience != blank %}
                  <details class="event-accordion-item">
                    <summary>
                      <span>BEAUTY BAR EXPERIENCE</span>
                      <span class="event-accordion-icon" aria-hidden="true">
                        <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                          <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                    </summary>
                    <div class="event-accordion-panel">
                      {{ product.metafields.custom.beauty_bar_experience | metafield_tag }}
                    </div>
                  </details>
                {% endif %}
                {% if product.metafields.custom.who_is_this_for != blank %}
                  <details class="event-accordion-item">
                    <summary>
                      <span>WHO IS THIS FOR</span>
                      <span class="event-accordion-icon" aria-hidden="true">
                        <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                          <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                    </summary>
                    <div class="event-accordion-panel">
                      {{ product.metafields.custom.who_is_this_for | metafield_tag }}
                    </div>
                  </details>
                {% endif %}
                {% if product.metafields.custom.event_flow != blank %}
                  <details class="event-accordion-item">
                    <summary>
                      <span>EVENT FLOW</span>
                      <span class="event-accordion-icon" aria-hidden="true">
                        <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                          <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                    </summary>
                    <div class="event-accordion-panel">
                      {{ product.metafields.custom.event_flow | metafield_tag }}
                    </div>
                  </details>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {%- endif -%}

      {%- if event_hero == blank -%}
        <div class="pd-content-body">
          {% if product.description != blank %}
            <div class="pd-desc rte">
              {{ product.description }}
            </div>
          {% endif %}

          {% if current_variant_wte != blank
            or product.metafields.custom.beauty_bar_experience != blank
            or product.metafields.custom.who_is_this_for != blank
            or product.metafields.custom.event_flow != blank
          %}
            <div class="event-accordion{% if product.variants.size > 1 and current_variant_wte != blank %}{% if has_other_accordion %} event-accordion--wte-mobile-hidden{% else %} event-accordion--has-mobile-copy{% endif %}{% endif %}">
              {% if current_variant_wte != blank %}
                <div class="event-accordion-item event-accordion-item--static">
                  <div class="event-accordion-static-heading">WHAT TO EXPECT</div>
                  <div class="event-accordion-panel" data-what-to-expect-panel>
                    {{ current_variant_wte | metafield_tag }}
                  </div>
                </div>
              {% endif %}
              {% if product.metafields.custom.beauty_bar_experience != blank %}
                <details class="event-accordion-item">
                  <summary>
                    <span>BEAUTY BAR EXPERIENCE</span>
                    <span class="event-accordion-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                  </summary>
                  <div class="event-accordion-panel">
                    {{ product.metafields.custom.beauty_bar_experience | metafield_tag }}
                  </div>
                </details>
              {% endif %}
              {% if product.metafields.custom.who_is_this_for != blank %}
                <details class="event-accordion-item">
                  <summary>
                    <span>WHO IS THIS FOR</span>
                    <span class="event-accordion-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                  </summary>
                  <div class="event-accordion-panel">
                    {{ product.metafields.custom.who_is_this_for | metafield_tag }}
                  </div>
                </details>
              {% endif %}
              {% if product.metafields.custom.event_flow != blank %}
                <details class="event-accordion-item">
                  <summary>
                    <span>EVENT FLOW</span>
                    <span class="event-accordion-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                  </summary>
                  <div class="event-accordion-panel">
                    {{ product.metafields.custom.event_flow | metafield_tag }}
                  </div>
                </details>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {%- endif -%}
    </div>

    {% if is_event_template %}
      {% if show_book_cta or show_waitlist_cta %}
        <div class="pd-event-sticky-cta" data-event-sticky-cta>
          <button
            type="button"
            class="button button--primary pd-secure-seat-btn pd-event-sticky-cta__btn"
            data-event-sticky-btn
          >
            {{ sticky_cta_label }}
          </button>
        </div>
      {% endif %}
    {% endif %}
  </div>
{% else %}
  <div class="past-event-details-wr">
    <div class="ped-inner ga-section-container">
      <div class="ped-header">
        <div class="ped-title">{{ product.title }}</div>
        <div class="ped-subtitle">
          {% if host %}
            <div class="ped-host">{{ host }}</div>
          {% endif %}
          <div class="ped-date">{{ event_date | date: '%a, %d %b' -}}</div>
          <div class="ped-time">{{ event_time }}</div>
        </div>
        <div class="ped-summary">
          {{ event_summary }}
        </div>
      </div>
      {% if event_images != empty %}
        <div class="ped-gallery-wr">
          <ul class="ped-gallery">
            {% for image in event_images %}
              <li class="ped-gallery-image-wr">
                {{ image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'pred-gallery-image' }}
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const accordionItems = document.querySelectorAll('.event-accordion-item');

    accordionItems.forEach((item) => {
      item.addEventListener('toggle', () => {
        if (!item.open) return;

        accordionItems.forEach((other) => {
          if (other !== item) {
            other.open = false;
          }
        });
      });
    });

    // ---- Event image carousel ----
    document.querySelectorAll('[data-pd-carousel]').forEach(function (carousel) {
      const viewport = carousel.querySelector('[data-pd-carousel-viewport]');
      const slides = carousel.querySelectorAll('.pd-carousel__slide');
      const prevBtn = carousel.querySelector('[data-pd-carousel-prev]');
      const nextBtn = carousel.querySelector('[data-pd-carousel-next]');
      const dots = carousel.querySelectorAll('[data-pd-carousel-dot]');
      if (!viewport || slides.length < 2) return;

      let index = 0;

      function updateDots() {
        dots.forEach(function (dot, di) {
          dot.classList.toggle('is-active', di === index);
        });
      }

      function goTo(i) {
        index = Math.max(0, Math.min(slides.length - 1, i));
        viewport.scrollTo({ left: viewport.clientWidth * index, behavior: 'smooth' });
        updateDots();
      }

      if (prevBtn) prevBtn.addEventListener('click', function () { goTo(index - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function () { goTo(index + 1); });
      dots.forEach(function (dot, di) {
        dot.addEventListener('click', function () { goTo(di); });
      });

      let scrollTimer;
      viewport.addEventListener('scroll', function () {
        window.clearTimeout(scrollTimer);
        scrollTimer = window.setTimeout(function () {
          index = Math.round(viewport.scrollLeft / viewport.clientWidth);
          updateDots();
        }, 90);
      });
    });

    const checkoutUrl = {{ routes.root_url | append: 'checkout' | json }};
    const cartAddUrl = {{ routes.cart_add_url | json }};
    const eventSheetWebhook = {{ section.settings.waitlist_sheet_webhook | strip | json }};
    const eventSheetTitle = {{ product.title | json }};
    const eventSheetHandle = {{ product.handle | json }};
    const eventCheckoutMode = {{ event_checkout_mode | json }};
    let eventSheetAmount = {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros | strip_html | json }};
    const eventVariantId = {{ event_variant.id | json }};

    // ---- Event ticket variant switching ----
    (function () {
      const payloadsRoot = document.querySelector('[data-event-variant-payloads]');
      if (!payloadsRoot) return;

      const picker = document.querySelector('[data-event-variant-picker]');
      const dropdown = document.querySelector('[data-event-variant-dropdown]');
      const priceAmountEl = document.querySelector('.pd-event-price-per-seat__amount');
      const dateValueEl = document.querySelector('[data-event-date-value]');
      const timingsTile = document.querySelector('[data-event-timings-tile]');
      const timingsValueEl = document.querySelector('[data-event-timings-value]');
      const wtePanels = document.querySelectorAll('[data-what-to-expect-panel]');
      const bookingForm = document.querySelector('[data-event-booking-form]');
      const idInput = bookingForm ? bookingForm.querySelector('input[name="id"]') : null;
      const submitBtn = bookingForm ? bookingForm.querySelector('[type="submit"]') : null;
      const defaultSubmitLabel = submitBtn ? submitBtn.textContent.trim() : '';

      function applyVariant(variantId) {
        const tpl = payloadsRoot.querySelector('template[data-variant-id="' + variantId + '"]');
        if (!tpl) return;

        eventSheetAmount = tpl.dataset.price || eventSheetAmount;

        if (priceAmountEl && tpl.dataset.price) {
          priceAmountEl.textContent = tpl.dataset.price;
        }
        if (dateValueEl && tpl.dataset.date) {
          dateValueEl.textContent = tpl.dataset.date;
        }
        if (timingsTile) {
          const time = (tpl.dataset.time || '').trim();
          if (time) {
            if (timingsValueEl) timingsValueEl.textContent = time;
            timingsTile.hidden = false;
          } else {
            timingsTile.hidden = true;
          }
        }
        wtePanels.forEach(function (panel) {
          panel.innerHTML = tpl.innerHTML;
        });
        if (bookingForm) bookingForm.dataset.variantId = variantId;
        if (idInput) idInput.value = variantId;

        const available = tpl.dataset.available === 'true';
        if (submitBtn) {
          submitBtn.disabled = !available;
          submitBtn.textContent = available ? defaultSubmitLabel : 'Sold Out';
        }
      }

      function syncControls(variantId) {
        if (picker) {
          picker.querySelectorAll('[data-variant-select]').forEach(function (btn) {
            const selected = btn.dataset.variantId === variantId;
            btn.classList.toggle('is-selected', selected);
            btn.setAttribute('aria-pressed', selected ? 'true' : 'false');
          });
        }
        if (dropdown && dropdown.value !== variantId) {
          dropdown.value = variantId;
        }
      }

      function selectVariant(variantId) {
        syncControls(variantId);
        applyVariant(variantId);
      }

      if (picker) {
        picker.querySelectorAll('[data-variant-select]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            selectVariant(btn.dataset.variantId);
          });
        });
      }

      if (dropdown) {
        dropdown.addEventListener('change', function () {
          selectVariant(dropdown.value);

          if (window.matchMedia('(max-width: 749px)').matches) {
            const scrollTarget =
              document.querySelector('.event-accordion-static-heading') ||
              bookingForm ||
              document.querySelector('[data-event-primary-cta] [data-event-book-now]');
            if (scrollTarget) {
              scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
        });
      }
    })();

    function postEventSheet(payload) {
      if (!eventSheetWebhook) return Promise.resolve({ skipped: true });
      var url = new URL(eventSheetWebhook);
      Object.keys(payload).forEach(function (key) {
        var value = payload[key];
        if (value !== undefined && value !== null && String(value).length) {
          url.searchParams.set(key, String(value));
        }
      });
      return fetch(url.toString(), { method: 'GET', credentials: 'omit' })
        .then(function (res) {
          return res.json().catch(function () {
            return {};
          });
        });
    }

    document.querySelectorAll('[data-event-booking-form]').forEach(function (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();

        const variantId = parseInt(form.dataset.variantId || form.querySelector('[name="id"]')?.value, 10);
        if (!variantId || Number.isNaN(variantId)) {
          window.alert('This event is not available for booking right now. Please refresh or contact us.');
          return;
        }

        const submitBtn = form.querySelector('[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.setAttribute('aria-busy', 'true');
        }

        const formData = new FormData(form);
        const properties = {};
        formData.forEach(function (value, key) {
          const match = key.match(/^properties\[(.+)\]$/);
          if (match) properties[match[1]] = value;
        });

        const item = { id: variantId, quantity: 1 };
        if (Object.keys(properties).length) item.properties = properties;

        postEventSheet({
          sheet: eventSheetTitle,
          event_title: eventSheetTitle,
          event_handle: eventSheetHandle,
          name: properties['Attendee name'] || properties['Name'] || '',
          email: properties['Email'] || '',
          phone: properties['Phone'] || '',
          status: 'checkout_started',
          checkout_mode: eventCheckoutMode || 'shopify_checkout',
          variant_id: String(variantId),
          amount: eventSheetAmount,
          page_url: window.location.href
        }).catch(function () {});

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ items: [item] })
        })
          .then(function (res) {
            return res.json().then(function (data) {
              if (!res.ok) throw data;
              return data;
            });
          })
          .then(function () {
            window.location.href = checkoutUrl;
          })
          .catch(function () {
            form.action = cartAddUrl;
            if (!form.querySelector('[name="return_to"]')) {
              const returnInput = document.createElement('input');
              returnInput.type = 'hidden';
              returnInput.name = 'return_to';
              returnInput.value = checkoutUrl;
              form.appendChild(returnInput);
            }
            form.submit();
          });
      });
    });

    const waitlistForm = document.getElementById('EventWaitlistOnlyForm');
    if (waitlistForm) {
      const waitlistProductHandle = {{ product.handle | json }};

      waitlistForm.addEventListener('submit', function(e) {
        if (waitlistForm.dataset.submitting === 'true') return;
        e.preventDefault();

        const nameInput = document.getElementById('EventWaitlistOnly-first-name');
        const emailInput = document.getElementById('EventWaitlistOnly-email');
        const phoneInput = document.getElementById('EventWaitlistOnly-phone');
        const cityInput = document.getElementById('EventWaitlistOnly-city');
        const tagsInput = waitlistForm.querySelector('input[name="contact[tags]"]');
        const submitBtn = waitlistForm.querySelector('.waitlist-submit-btn');

        if (
          !nameInput ||
          !emailInput ||
          !phoneInput ||
          !cityInput ||
          !nameInput.value.trim() ||
          !emailInput.value.trim() ||
          !phoneInput.value.trim() ||
          !cityInput.value.trim()
        ) {
          return;
        }

        const citySlug = cityInput.value.trim().toLowerCase().replace(/\s+/g, '-');
        const phoneTag = phoneInput.value.trim().replace(/[^\d+]/g, '');

        if (tagsInput) {
          tagsInput.value = 'event-waitlist, ' + waitlistProductHandle + ', city-' + citySlug + ', phone-' + phoneTag;
        }

        waitlistForm.dataset.submitting = 'true';
        submitBtn.disabled = true;
        submitBtn.textContent = 'SUBMITTING...';

        const sheetPayload = {
          sheet: eventSheetTitle,
          event_title: eventSheetTitle,
          event_handle: eventSheetHandle,
          name: nameInput.value.trim(),
          email: emailInput.value.trim(),
          phone: phoneInput.value.trim(),
          city: cityInput.value.trim(),
          status: 'waitlist',
          checkout_mode: 'waitlist',
          amount: eventSheetAmount,
          page_url: window.location.href,
          shopify_customer: 'yes'
        };

        postEventSheet(sheetPayload)
          .catch(function () {})
          .finally(function () {
            waitlistForm.submit();
          });
      });
    }

    document.querySelectorAll('[data-event-book-now].pd-cta-button').forEach(function (link) {
      link.addEventListener('click', function () {
        postEventSheet({
          sheet: eventSheetTitle,
          event_title: eventSheetTitle,
          event_handle: eventSheetHandle,
          status: 'payment_link',
          checkout_mode: eventCheckoutMode || 'payment_link',
          amount: eventSheetAmount,
          page_url: window.location.href,
          notes: 'Payment link opened'
        }).catch(function () {});
      });
    });

    const eventRoot = document.body;
    if (
      eventRoot.classList.contains('template-product-event') &&
      eventRoot.dataset.eventStickyInit !== 'true'
    ) {
      eventRoot.dataset.eventStickyInit = 'true';

      const stickyCta = eventRoot.querySelector('[data-event-sticky-cta]');
      const stickyBtn = eventRoot.querySelector('[data-event-sticky-btn]');
      const mobileMq = window.matchMedia('(max-width: 749px)');
      let stickyObserver = null;

      const getStickyWatchTarget = () =>
        eventRoot.querySelector('[data-event-booking-form] [type="submit"]:not([disabled])') ||
        eventRoot.querySelector('#EventWaitlistOnlyForm [type="submit"]') ||
        eventRoot.querySelector('[data-event-primary-cta] [data-event-book-now]');

      if (stickyCta && stickyBtn) {
        const setCtaInView = (inView) => {
          if (inView) {
            eventRoot.classList.add('is-event-cta-in-view');
          } else {
            eventRoot.classList.remove('is-event-cta-in-view');
          }
        };

        const connectStickyObserver = () => {
          if (stickyObserver) stickyObserver.disconnect();
          if (!mobileMq.matches) {
            eventRoot.classList.remove('is-event-cta-in-view');
            return;
          }

          const watchTarget = getStickyWatchTarget();
          if (!watchTarget) {
            eventRoot.classList.remove('is-event-cta-in-view');
            return;
          }

          const barPx =
            parseInt(getComputedStyle(eventRoot).getPropertyValue('--pd-event-sticky-bar'), 10) || 72;

          stickyObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => setCtaInView(entry.isIntersecting));
            },
            {
              root: null,
              threshold: 0,
              rootMargin: '0px 0px -' + barPx + 'px 0px'
            }
          );

          stickyObserver.observe(watchTarget);
        };

        stickyBtn.addEventListener('click', () => {
          const watchTarget = getStickyWatchTarget();
          if (!watchTarget) return;
          watchTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
          window.setTimeout(() => watchTarget.focus(), 400);
        });

        mobileMq.addEventListener('change', connectStickyObserver);
        connectStickyObserver();
      }
    }
  });
</script>

