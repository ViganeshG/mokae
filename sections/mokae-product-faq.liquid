{{ 'section-mokae-product-details.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign faq_items = product.metafields.custom.faqs.value
  assign has_faqs = false

  if faq_items != blank and faq_items.size > 0
    assign has_faqs = true
  endif
-%}

{%- if has_faqs -%}
  <section class="mokae-product-faq" data-id="shopify-section-{{ section.id }}">
    <div class="fullscreen-container">
      <h2 class="mokae-product-faq__heading">FAQs</h2>

      <div class="about mokae-product-faq__accordion">
        <div class="about__outer">
          <div class="about__right">
            <div class="about__wrapper no-js-hidden mokae-product-faq__wrapper">
              {%- for item in faq_items -%}
                {%- if item != blank -%}
                  {%- liquid
                    assign faq_parts = item | split: '||'
                    if faq_parts.size < 2
                      assign faq_parts = item | split: '::'
                    endif

                    assign faq_question = faq_parts[0] | strip
                    assign faq_answer = faq_parts[1] | strip
                  -%}

                  {%- if faq_question != blank -%}
                    <div class="about__accordion-item mokae-product-faq__item">
                      <h2 class="about__accordion-title">
                        <span>{{ faq_question }}</span>
                        <div class="about__more-link-wrapper">
                          <div class="about__more-link">{% render 'icon-button-arrow' %}</div>
                        </div>
                      </h2>

                      {%- if faq_answer != blank -%}
                        <div class="about__accordion-description mokae-product-faq__answer" style="display: none">
                          <p>{{ faq_answer }}</p>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Mokae Product FAQ",
  "tag": "section",
  "class": "mokae-product-faq-section",
  "settings": [],
  "presets": [
    {
      "name": "Mokae Product FAQ"
    }
  ]
}
{% endschema %}
