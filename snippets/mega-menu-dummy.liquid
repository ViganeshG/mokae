<span
  class="header__menu-item list-menu__item list-menu__item-first link"
  {% if link.current %}
    aria-current="page"
  {% endif %}
  aria-label="{{ link.title | escape }}"
>
  <span
    {%- if link.active %}
      class="header__active-menu-item"
    {% endif %}
    title="{{ link.title | escape }}"
  >
    <span>{{ link.title | escape }}</span>
  </span>
</span>

<div class="header-mega-menu color-background-1">

  {% assign main_metaobject = metaobjects.megamenu['megamenu-op-1'] %}

  {% if main_metaobject %}
    <div class="mega-menu-new mega-menu-new-2">
      <div class="mm-container">

        <!-- LEFT SIDE LINKS -->
        <div class="mm-links">
          <ul>
            {% for block in main_metaobject.menu_item.value %}
              <li data-index="{{ forloop.index0 }}">
                <a href="{{ block.url }}">{{ block.link_lanel }}</a>
              </li>
            {% endfor %}
          </ul>
          <div class="mm-shop-all">
            <a href="/collections/all" class="shop-all-btn">SHOP ALL</a>
          </div>
        </div>

        <!-- RIGHT SIDE IMAGES -->
        <div class="mm-hero">

          <!-- LEFT COLUMN (image 1) -->
          <div class="mm-hero-half mm-h-l">
            {% for block in main_metaobject.menu_item.value %}
              {% if block.images != blank %}
                <img 
                  src="{{ block.images | image_url: width:1200 }}" 
                  class="two-col-img" 
                  data-index="{{ forloop.index0 }}"
                  style="opacity:0"
                >
              {% endif %}
            {% endfor %}
          </div>

          <!-- RIGHT COLUMN (image 2) -->
          <div class="mm-hero-half mm-h-r">
            {% for block in main_metaobject.menu_item.value %}
              {% if block.images_2 != blank %}
                <img 
                  src="{{ block.images_2 | image_url: width:1200 }}" 
                  class="two-col-img" 
                  data-index="{{ forloop.index0 }}"
                  style="opacity:0"
                >
              {% endif %}
            {% endfor %}
          </div>

          <!-- FULL WIDTH FALLBACK -->
          {% for block in main_metaobject.menu_item.value %}
            {% if block.images == blank and block.images_2 == blank and block.full_width_image != blank %}
              <img
                src="{{ block.full_width_image | image_url: width:1600 }}"
                class="full-width-img"
                data-index="{{ forloop.index0 }}"
                style="opacity:0"
              >
            {% endif %}
          {% endfor %}

        </div>
      </div>
    </div>
  {% endif %}
</div>

<div class="mega-menu_overflow"></div>

<!-- JS HANDLER -->
<script>
document.addEventListener('DOMContentLoaded', () => {

  const items = document.querySelectorAll('.mm-links ul li');

  const leftImgs = document.querySelectorAll('.mm-h-l img');
  const rightImgs = document.querySelectorAll('.mm-h-r img');
  const fullImgs = document.querySelectorAll('.full-width-img');

  items.forEach((item) => {
    const idx = item.dataset.index;

    item.addEventListener('mouseenter', () => {

      // hide everything first
      [...leftImgs, ...rightImgs, ...fullImgs].forEach(img => img.style.opacity = 0);

      // If two column images exist → show them
      const leftImg = document.querySelector(`.mm-h-l img[data-index="${idx}"]`);
      const rightImg = document.querySelector(`.mm-h-r img[data-index="${idx}"]`);

      if (leftImg || rightImg) {
        if (leftImg) leftImg.style.opacity = 1;
        if (rightImg) rightImg.style.opacity = 1;
      } else {
        // otherwise show full width
        const fullImg = document.querySelector(`.full-width-img[data-index="${idx}"]`);
        if (fullImg) fullImg.style.opacity = 1;
      }

    });
  });
});
</script> {% endcomment %}
