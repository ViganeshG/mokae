          <div class="mm-hero">
            {% for block in main_metaobject.menu_item.value %}
              <img
                src="{{ block.full_width_image  | image_url: width:1200 }}"
              >

            {% endfor %}
          </div>
        {% endif %}
        </div>
      </div>
    {% endif %}
  {% endcomment %}
