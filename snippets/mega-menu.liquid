<span
  class="header__menu-item list-menu__item list-menu__item-first link"
  {% if link.current %}
    aria-current="page"
  {% endif %}
  aria-label="{{ link.title | escape }}"
>
  <span
    {%- if link.active %}
      class="header__active-menu-item"
    {% endif %}
    title="{{ link.title | escape }}"
  >
    <span>{{ link.title | escape }}</span>
  </span>
</span>

<div class="header-mega-menu color-background-2">

  {% assign main_metaobject = metaobjects.megamenu['megamenu-op-2'] %}

  {% if link.links.size > 0 or main_metaobject %}
    <div class="mega-menu-new mega-menu-new-2">
      <div class="mm-container">

        <!-- LEFT SIDE LINKS -->
        <div class="mm-links">
          <ul>
            {%- if link.links.size > 0 -%}
              {%- assign mm_link_index = 0 -%}
              {%- for childlink in link.links -%}
                {%- assign child_title_downcase = childlink.title | downcase | strip -%}
                {%- unless child_title_downcase == 'shop all' -%}
                  <li data-index="{{ mm_link_index }}">
                    <a href="{{ childlink.url }}">{{ childlink.title }}</a>
                  </li>
                  {%- assign mm_link_index = mm_link_index | plus: 1 -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- elsif main_metaobject -%}
              {%- for block in main_metaobject.menu_item.value -%}
                <li data-index="{{ forloop.index0 }}">
                  <a href="{{ block.url }}">{{ block.link_lanel }}</a>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>

          <div class="mm-shop-all">
            <a href="/collections/all" class="shop-all-btn" data-index="shopall">SHOP ALL</a>
          </div>
        </div>

        <!-- RIGHT SIDE IMAGES -->
        <div class="mm-hero">
          <!-- DEFAULT fallback image -->
          <img 
            src="https://cdn.shopify.com/s/files/1/0707/6472/4465/files/Shop_463ab9ef-eadf-4871-8ac8-0841b6877441.png?v=1765796284"
            class="default-mm-img"
            style="opacity:1"
          >
          <!-- LEFT COLUMN -->
          <div class="mm-hero-half mm-h-l">
            {% if main_metaobject %}
              {% for block in main_metaobject.menu_item.value %}
                {% if block.images != blank %}
                  <img 
                    src="{{ block.images | image_url: width:1200 }}" 
                    class="two-col-img" 
                    data-index="{{ forloop.index0 }}"
                    style="opacity:0"
                  >
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
          <!-- RIGHT COLUMN -->
          <div class="mm-hero-half mm-h-r">
            {% if main_metaobject %}
              {% for block in main_metaobject.menu_item.value %}
                {% if block.images_2 != blank %}
                  <img 
                    src="{{ block.images_2 | image_url: width:1200 }}" 
                    class="two-col-img" 
                    data-index="{{ forloop.index0 }}"
                    style="opacity:0"
                  >
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>

          <!-- FULL WIDTH FALLBACK -->
          {% if main_metaobject %}
            {% for block in main_metaobject.menu_item.value %}
              {% if block.images == blank and block.images_2 == blank and block.full_width_image != blank %}
                <img
                  src="{{ block.full_width_image | image_url: width:1600 }}"
                  class="full-width-img"
                  data-index="{{ forloop.index0 }}"
                  style="opacity:0"
                >
              {% endif %}
            {% endfor %}
          {% endif %}

        </div>
      </div>
    </div>
  {% endif %}
</div>

<div class="mega-menu_overflow"></div>

<!-- JS HANDLER -->
<script>
document.addEventListener('DOMContentLoaded', () => {

  const items     = document.querySelectorAll('.mm-links li');
  const shopAll   = document.querySelector('.shop-all-btn');
  const leftImgs  = document.querySelectorAll('.mm-h-l img');
  const rightImgs = document.querySelectorAll('.mm-h-r img');
  const fullImgs  = document.querySelectorAll('.full-width-img');
  const defaultImg = document.querySelector('.default-mm-img');

  // Reset all images
  function hideAll() {
    [...leftImgs, ...rightImgs, ...fullImgs].forEach(img => img.style.opacity = 0);
    defaultImg.style.opacity = 0;
  }

  // DEFAULT ON MENU OPEN
  function showDefault() {
    hideAll();
    defaultImg.style.opacity = 1;
  }

  showDefault();

  // Hover over regular menu items
  items.forEach(item => {
    item.addEventListener('mouseenter', () => {
      const index = item.dataset.index;

      hideAll();

      const left  = document.querySelector(`.mm-h-l img[data-index="${index}"]`);
      const right = document.querySelector(`.mm-h-r img[data-index="${index}"]`);
      const full  = document.querySelector(`.full-width-img[data-index="${index}"]`);

      if (left || right) {
        if (left) left.style.opacity = 1;
        if (right) right.style.opacity = 1;
      } else if (full) {
        full.style.opacity = 1;
      }
    });
  });

  // ★ SHOW DEFAULT IMAGE WHEN HOVER SHOP ALL
  shopAll.addEventListener('mouseenter', () => {
    showDefault();
  });

});
</script>
