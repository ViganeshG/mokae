{%- comment -%}
  Razorpay Magic Checkout disabled — native Shopify checkout is active.
  To re-enable: remove the comment tags in this file AND in layout/theme.liquid
  around the {% render 'razorpay-magic-checkout' %} call.

  Original code preserved below:
  <div id="magic-checkout-data-container">
    <script src="https://magic-plugins.razorpay.com/shopify/magic-shopify.js" crossorigin="anonymous" defer></script>
    <script id="RazorpayMagicCheckoutConfig" type="application/json">
      {"oneClickCheckoutEnabled":"{{shop.metafields.magic_checkout.oneClickCheckoutEnabled}}","buyNowEnabled":"{{shop.metafields.magic_checkout.buyNowEnabled}}","config":{{shop.metafields.magic_checkout.config}},"email":"{{customer.email}}","phone":"{{customer.phone}}"}
    </script>
  </div>
{%- endcomment -%}